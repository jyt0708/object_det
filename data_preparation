# Step 3: 标签转换函数 (YOLO格式)
def convert_to_yolo(line, class_map, img_w, img_h):
    parts = line.strip().split(',')
    if len(parts) < 6:
        return None
    
    x1, y1, x2, y2, cls, _ = parts
    
    if cls not in class_map:
        return None
    
    x1, y1, x2, y2 = map(float, [x1, y1, x2, y2])
    x_center = (x1 + x2) / 2 / img_w
    y_center = (y1 + y2) / 2 / img_h
    width = (x2 - x1) / img_w
    height = (y2 - y1) / img_h
    
    return f"{class_map[cls]} {x_center:.6f} {y_center:.6f} {width:.6f} {height:.6f}\n"

# Step 4: 处理train/val标签和图片

def process_dataset(label_src, img_src, label_dst, img_dst):
    for i, txt_file in enumerate(os.listdir(label_src), start=1):
        if not txt_file.endswith('.txt'):
            continue
        src_label_path = os.path.join(label_src, txt_file)
        src_img_path = os.path.join(img_src, txt_file.replace('.txt', '.jpg'))
        if not os.path.exists(src_img_path):
            continue

        # 获取图片尺寸
        img = Image.open(src_img_path)
        img_w, img_h = img.size

        # 转换标签
        yolo_lines = []
        with open(src_label_path, 'r') as f:
            for line in f:
                yolo_line = convert_to_yolo(line, class_map, img_w, img_h)
                if yolo_line:
                    yolo_lines.append(yolo_line)

        if len(yolo_lines) == 0:
            continue  # 标签中没有符合的类别

        # 保存YOLO标签
        dst_label_path = os.path.join(label_dst, txt_file)
        with open(dst_label_path, 'w') as f:
            f.writelines(yolo_lines)

        # 复制图片
        dst_img_path = os.path.join(img_dst, os.path.basename(src_img_path))
        shutil.copy(src_img_path, dst_img_path)

        if i % 1000 == 0:
            print(f"Processed {i} files in dataset {label_src}...")

process_dataset(label_train, img_train, label_train_new, img_train_new)
