    print(f"标注数量: {summary['val']['annotations']}")

    print("\n" + "=" * 80)
    print(f"{'ID':<5} {'类别名称':<35} {'Train Count':<15} {'Val Count':<15}")
    print("-" * 80)

    for item in summary["per_class"]:
        print(
            f"{item['class_id']:<5} "
            f"{item['class_name']:<35} "
            f"{item['train_count']:<15} "
            f"{item['val_count']:<15}"
        )

    print("=" * 80 + "\n")

