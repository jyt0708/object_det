from pathlib import Path
from collections import defaultdict

id_to_name = {v: k for k, v in class_map.items()}
valid_class_ids = set(class_map.values())

def summarize_class_distribution(label_new_dir, dataset_name="过滤后数据集"):
    """
    统计每个类别的标注数量
    
    Args:
        label_new_dir: 标签文件目录
        dataset_name: 数据集名称
    
    Returns:
        dict: 类别统计字典
    """
    class_counts = defaultdict(int)
    total_annotations = 0
    total_images = 0
    
    # 遍历所有标签文件
    label_files = list(Path(label_new_dir).glob("*.txt"))
    
    for label_file in label_files:
        with open(label_file, 'r') as f:
            lines = f.readlines()
        
        if lines:  # 如果文件不为空
            total_images += 1
            
        for line in lines:
            line = line.strip()
            if not line:
                continue
                
            parts = line.split()
            if len(parts) < 5:
                continue
                
            try:
                class_id = int(parts[0])
                if class_id in valid_class_ids:
                    class_counts[class_id] += 1
                    total_annotations += 1
            except ValueError:
                continue
    
    # 转换为易于阅读的格式
    summary = {
        "dataset": dataset_name,
        "total_images": total_images,
        "total_annotations": total_annotations,
        "class_distribution": {},
        "class_counts": dict(class_counts)
    }
    
    # 按类别名称排序
    for class_id in sorted(class_counts.keys()):
        class_name = id_to_name.get(class_id, f"Unknown_{class_id}")
        count = class_counts[class_id]
        summary["class_distribution"][class_name] = count
    
    return summary


def summarize_train_val_by_class(train_label_dir, val_label_dir):
    train_summary = summarize_class_distribution(train_label_dir, "Train")
    val_summary = summarize_class_distribution(val_label_dir, "Validation")

    all_class_ids = sorted(set(train_summary["class_counts"].keys()) |
                           set(val_summary["class_counts"].keys()))

    summary = {
        "train": {
            "images": train_summary["total_images"],
            "annotations": train_summary["total_annotations"],
            "class_counts": train_summary["class_counts"]
        },
        "val": {
            "images": val_summary["total_images"],
            "annotations": val_summary["total_annotations"],
            "class_counts": val_summary["class_counts"]
        },
        "per_class": []
    }

    for cid in all_class_ids:
        summary["per_class"].append({
            "class_id": cid,
            "class_name": id_to_name.get(cid, f"Unknown_{cid}"),
            "train_count": train_summary["class_counts"].get(cid, 0),
            "val_count": val_summary["class_counts"].get(cid, 0),
        })

    return summary



