# Step 1: 统计每个validation标签类别instance数
train_counter = Counter()
val_counter = Counter()

def count_instances(label_folder, counter, name):
    for i, txt_file in enumerate(os.listdir(label_folder), start=1):
        if not txt_file.endswith('.txt'):
            continue

        file_path = os.path.join(label_folder, txt_file)
        classes_in_file = set()

        with open(file_path, 'r') as f:
            for line in f:
                parts = line.strip().split(',')
                if len(parts) < 5:
                    continue
                cls = parts[4]
                classes_in_file.add(cls)

        counter.update(classes_in_file)

        if i % 1000 == 0:
            print(f"Processed {i} files in {name}...")

count_instances(label_train, train_counter, "train")
count_instances(label_val, val_counter, "val")

# 所有出现过的类别
all_classes = set(train_counter.keys()) | set(val_counter.keys())

# 先按阈值筛选
filtered_classes = [
    cls for cls in all_classes
    if train_counter[cls] >= 150 and val_counter[cls] >= 50
]

# 按 train + val 总 instance 排序，取前 38
filtered_classes = sorted(
    filtered_classes,
    key=lambda c: train_counter[c] + val_counter[c],
    reverse=True
)[:38]

class_map = {cls_name: idx for idx, cls_name in enumerate(filtered_classes)}


